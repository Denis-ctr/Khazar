  idt[num].low_offset = (uint16_t)(base & 0xFFFF); // adressin 0-15 bitleri
  idt[num].mid_offset =
      (uint16_t)((base >> 16) & 0xFFFF); // adressin 16-31 bitleri
  idt[num].high_offset =
      (uint32_t)((base >> 32) & 0xFFFFFFFF); // adressin 32-63 bitleri

